generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  description String?
  prompt      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
